/**
 * LaTeX数学公式解析器 - 基于改进版BNF范式
 * 
 * 核心特性：
 * 1. 递归下降解析
 * 2. 无左递归
 * 3. 递归深度限制
 * 4. 清晰的错误信息
 */

import java.util.*;

// ==================== AST节点定义 ====================

interface MathNode {
    String toLatex();
}

class MathList implements MathNode {
    List<Term> terms;
    List<String> operators;
    
    public MathList(List<Term> terms, List<String> operators) {
        this.terms = terms;
        this.operators = operators;
    }
    
    @Override
    public String toLatex() {
        StringBuilder sb = new StringBuilder();
        for (int i = 0; i < terms.size(); i++) {
            sb.append(terms.get(i).toLatex());
            if (i < operators.size()) {
                sb.append(operators.get(i));
            }
        }
        return sb.toString();
    }
}

class Term implements MathNode {
    Atom atom;
    SupSubSuffix suffix;  // 可选
    
    public Term(Atom atom, SupSubSuffix suffix) {
        this.atom = atom;
        this.suffix = suffix;
    }
    
    @Override
    public String toLatex() {
        String result = atom.toLatex();
        if (suffix != null) {
            result += suffix.toLatex();
        }
        return result;
    }
}

interface Atom extends MathNode {}

class NumberAtom implements Atom {
    String value;
    
    public NumberAtom(String value) {
        this.value = value;
    }
    
    @Override
    public String toLatex() {
        return value;
    }
}

class VariableAtom implements Atom {
    String name;
    
    public VariableAtom(String name) {
        this.name = name;
    }
    
    @Override
    public String toLatex() {
        return name;
    }
}

class GreekLetterAtom implements Atom {
    String symbol;  // 如 "alpha", "beta"
    
    public GreekLetterAtom(String symbol) {
        this.symbol = symbol;
    }
    
    @Override
    public String toLatex() {
        return "\\" + symbol;
    }
}

class GroupAtom implements Atom {
    MathList content;
    
    public GroupAtom(MathList content) {
        this.content = content;
    }
    
    @Override
    public String toLatex() {
        return "{" + content.toLatex() + "}";
    }
}

class FracAtom implements Atom {
    MathList numerator;
    MathList denominator;
    String command;  // "frac", "dfrac", "tfrac"
    
    public FracAtom(String command, MathList numerator, MathList denominator) {
        this.command = command;
        this.numerator = numerator;
        this.denominator = denominator;
    }
    
    @Override
    public String toLatex() {
        return "\\" + command + "{" + numerator.toLatex() + "}{" + denominator.toLatex() + "}";
    }
}

class SqrtAtom implements Atom {
    MathList content;
    MathList root;  // 可选，n次根
    
    public SqrtAtom(MathList content, MathList root) {
        this.content = content;
        this.root = root;
    }
    
    @Override
    public String toLatex() {
        String result = "\\sqrt";
        if (root != null) {
            result += "[" + root.toLatex() + "]";
        }
        result += "{" + content.toLatex() + "}";
        return result;
    }
}

class FunctionCallAtom implements Atom {
    String functionName;
    ScriptArg subscript;     // 可选
    ScriptArg superscript;   // 可选
    MathNode argument;       // 可选
    
    public FunctionCallAtom(String functionName, ScriptArg subscript, 
                           ScriptArg superscript, MathNode argument) {
        this.functionName = functionName;
        this.subscript = subscript;
        this.superscript = superscript;
        this.argument = argument;
    }
    
    @Override
    public String toLatex() {
        String result = "\\" + functionName;
        if (subscript != null) {
            result += "_" + subscript.toLatex();
        }
        if (superscript != null) {
            result += "^" + superscript.toLatex();
        }
        if (argument != null) {
            result += argument.toLatex();
        }
        return result;
    }
}

class LargeOperatorAtom implements Atom {
    String operatorName;  // "sum", "int", "prod"
    ScriptArg subscript;
    ScriptArg superscript;
    
    public LargeOperatorAtom(String operatorName, ScriptArg subscript, ScriptArg superscript) {
        this.operatorName = operatorName;
        this.subscript = subscript;
        this.superscript = superscript;
    }
    
    @Override
    public String toLatex() {
        String result = "\\" + operatorName;
        if (subscript != null) {
            result += "_" + subscript.toLatex();
        }
        if (superscript != null) {
            result += "^" + superscript.toLatex();
        }
        return result;
    }
}

class SupSubSuffix implements MathNode {
    ScriptArg superscript;
    ScriptArg subscript;
    
    public SupSubSuffix(ScriptArg superscript, ScriptArg subscript) {
        this.superscript = superscript;
        this.subscript = subscript;
    }
    
    @Override
    public String toLatex() {
        String result = "";
        if (superscript != null) {
            result += "^" + superscript.toLatex();
        }
        if (subscript != null) {
            result += "_" + subscript.toLatex();
        }
        return result;
    }
}

interface ScriptArg extends MathNode {}

class SingleTokenScriptArg implements ScriptArg {
    String token;
    
    public SingleTokenScriptArg(String token) {
        this.token = token;
    }
    
    @Override
    public String toLatex() {
        return token;
    }
}

class GroupScriptArg implements ScriptArg {
    MathList content;
    
    public GroupScriptArg(MathList content) {
        this.content = content;
    }
    
    @Override
    public String toLatex() {
        return "{" + content.toLatex() + "}";
    }
}

// ==================== 词法分析器 ====================

class Token {
    enum Type {
        NUMBER, LETTER, COMMAND, SYMBOL, LBRACE, RBRACE, 
        LBRACKET, RBRACKET, CARET, UNDERSCORE, EOF
    }
    
    Type type;
    String value;
    int position;
    
    public Token(Type type, String value, int position) {
        this.type = type;
        this.value = value;
        this.position = position;
    }
    
    @Override
    public String toString() {
        return type + "(" + value + ")";
    }
}

class Lexer {
    private String input;
    private int pos = 0;
    private List<Token> tokens = new ArrayList<>();
    
    public Lexer(String input) {
        this.input = input;
    }
    
    public List<Token> tokenize() throws ParseException {
        while (pos < input.length()) {
            char c = input.charAt(pos);
            
            // 跳过空白
            if (Character.isWhitespace(c)) {
                pos++;
                continue;
            }
            
            // 数字
            if (Character.isDigit(c)) {
                tokens.add(scanNumber());
            }
            // 命令 (如 \alpha, \frac)
            else if (c == '\\') {
                tokens.add(scanCommand());
            }
            // 字母
            else if (Character.isLetter(c)) {
                tokens.add(new Token(Token.Type.LETTER, String.valueOf(c), pos));
                pos++;
            }
            // 特殊符号
            else if (c == '{') {
                tokens.add(new Token(Token.Type.LBRACE, "{", pos));
                pos++;
            }
            else if (c == '}') {
                tokens.add(new Token(Token.Type.RBRACE, "}", pos));
                pos++;
            }
            else if (c == '[') {
                tokens.add(new Token(Token.Type.LBRACKET, "[", pos));
                pos++;
            }
            else if (c == ']') {
                tokens.add(new Token(Token.Type.RBRACKET, "]", pos));
                pos++;
            }
            else if (c == '^') {
                tokens.add(new Token(Token.Type.CARET, "^", pos));
                pos++;
            }
            else if (c == '_') {
                tokens.add(new Token(Token.Type.UNDERSCORE, "_", pos));
                pos++;
            }
            // 其他符号
            else {
                tokens.add(new Token(Token.Type.SYMBOL, String.valueOf(c), pos));
                pos++;
            }
        }
        
        tokens.add(new Token(Token.Type.EOF, "", pos));
        return tokens;
    }
    
    private Token scanNumber() {
        int start = pos;
        StringBuilder sb = new StringBuilder();
        
        // 整数部分
        while (pos < input.length() && Character.isDigit(input.charAt(pos))) {
            sb.append(input.charAt(pos++));
        }
        
        // 小数部分
        if (pos < input.length() && input.charAt(pos) == '.') {
            sb.append(input.charAt(pos++));
            while (pos < input.length() && Character.isDigit(input.charAt(pos))) {
                sb.append(input.charAt(pos++));
            }
        }
        
        return new Token(Token.Type.NUMBER, sb.toString(), start);
    }
    
    private Token scanCommand() throws ParseException {
        int start = pos;
        pos++;  // 跳过 \
        
        if (pos >= input.length()) {
            throw new ParseException("Unexpected end after backslash", start);
        }
        
        StringBuilder sb = new StringBuilder();
        
        // 扫描命令名（字母）
        while (pos < input.length() && Character.isLetter(input.charAt(pos))) {
            sb.append(input.charAt(pos++));
        }
        
        if (sb.length() == 0) {
            // 单字符命令，如 \{, \}, \|
            sb.append(input.charAt(pos++));
        }
        
        return new Token(Token.Type.COMMAND, sb.toString(), start);
    }
}

// ==================== 语法解析器 ====================

class MathParser {
    private List<Token> tokens;
    private int pos = 0;
    private int recursionDepth = 0;
    private static final int MAX_RECURSION_DEPTH = 100;
    
    // 二元运算符集合
    private static final Set<String> BINARY_OPERATORS = new HashSet<>(Arrays.asList(
        "+", "-", "*", "/", "=", "<", ">",
        "times", "cdot", "div", "pm", "mp",
        "neq", "equiv", "approx", "le", "ge", "leq", "geq",
        "in", "notin", "subset", "supset",
        "to", "rightarrow", "leftarrow"
    ));
    
    // 函数名集合
    private static final Set<String> FUNCTION_NAMES = new HashSet<>(Arrays.asList(
        "sin", "cos", "tan", "cot", "sec", "csc",
        "log", "ln", "exp", "lim", "max", "min"
    ));
    
    // 大型运算符集合
    private static final Set<String> LARGE_OPERATORS = new HashSet<>(Arrays.asList(
        "sum", "prod", "int", "oint", "bigcup", "bigcap"
    ));
    
    // 希腊字母集合
    private static final Set<String> GREEK_LETTERS = new HashSet<>(Arrays.asList(
        "alpha", "beta", "gamma", "delta", "epsilon", "theta", "lambda",
        "mu", "nu", "pi", "rho", "sigma", "tau", "phi", "chi", "psi", "omega"
    ));
    
    public MathParser(List<Token> tokens) {
        this.tokens = tokens;
    }
    
    // ========== 主入口 ==========
    
    public MathList parse() throws ParseException {
        MathList result = parseMathList();
        expect(Token.Type.EOF);
        return result;
    }
    
    // ========== 递归下降解析方法 ==========
    
    /**
     * <math_list> ::= <term> { <binary_op> <term> }
     */
    private MathList parseMathList() throws ParseException {
        checkRecursionDepth();
        
        List<Term> terms = new ArrayList<>();
        List<String> operators = new ArrayList<>();
        
        // 第一个term
        terms.add(parseTerm());
        
        // 后续的 op term 对
        while (isBinaryOperator()) {
            operators.add(consumeBinaryOperator());
            terms.add(parseTerm());
        }
        
        return new MathList(terms, operators);
    }
    
    /**
     * <term> ::= <atom> [ <sup_sub_suffix> ]
     */
    private Term parseTerm() throws ParseException {
        Atom atom = parseAtom();
        SupSubSuffix suffix = tryParseSupSubSuffix();
        return new Term(atom, suffix);
    }
    
    /**
     * <atom> ::= <number> | <variable> | <greek_letter> | <group> 
     *          | <frac> | <sqrt> | <function_call> | <large_operator> | ...
     */
    private Atom parseAtom() throws ParseException {
        Token token = currentToken();
        
        switch (token.type) {
            case NUMBER:
                return parseNumber();
            
            case LETTER:
                return parseVariable();
            
            case LBRACE:
                return parseGroup();
            
            case COMMAND:
                String cmd = token.value;
                
                if (cmd.equals("frac") || cmd.equals("dfrac") || cmd.equals("tfrac")) {
                    return parseFrac();
                }
                else if (cmd.equals("sqrt")) {
                    return parseSqrt();
                }
                else if (FUNCTION_NAMES.contains(cmd)) {
                    return parseFunctionCall();
                }
                else if (LARGE_OPERATORS.contains(cmd)) {
                    return parseLargeOperator();
                }
                else if (GREEK_LETTERS.contains(cmd)) {
                    return parseGreekLetter();
                }
                else {
                    throw new ParseException("Unknown command: \\" + cmd, token.position);
                }
            
            default:
                throw new ParseException("Expected atom, got " + token, token.position);
        }
    }
    
    /**
     * <number> ::= <digit> { <digit> } [ "." <digit> { <digit> } ]
     */
    private NumberAtom parseNumber() throws ParseException {
        Token token = expect(Token.Type.NUMBER);
        return new NumberAtom(token.value);
    }
    
    /**
     * <variable> ::= <letter>
     */
    private VariableAtom parseVariable() throws ParseException {
        Token token = expect(Token.Type.LETTER);
        return new VariableAtom(token.value);
    }
    
    /**
     * <greek_letter> ::= "\alpha" | "\beta" | ...
     */
    private GreekLetterAtom parseGreekLetter() throws ParseException {
        Token token = expect(Token.Type.COMMAND);
        return new GreekLetterAtom(token.value);
    }
    
    /**
     * <group> ::= "{" <math_list> "}"
     */
    private GroupAtom parseGroup() throws ParseException {
        expect(Token.Type.LBRACE);
        
        recursionDepth++;  // 进入递归
        try {
            MathList content = parseMathList();
            expect(Token.Type.RBRACE);
            return new GroupAtom(content);
        } finally {
            recursionDepth--;  // 退出递归
        }
    }
    
    /**
     * <frac> ::= "\frac" "{" <math_list> "}" "{" <math_list> "}"
     */
    private FracAtom parseFrac() throws ParseException {
        Token cmdToken = expect(Token.Type.COMMAND);
        String cmd = cmdToken.value;
        
        expect(Token.Type.LBRACE);
        recursionDepth++;
        try {
            MathList numerator = parseMathList();
            expect(Token.Type.RBRACE);
            
            expect(Token.Type.LBRACE);
            MathList denominator = parseMathList();
            expect(Token.Type.RBRACE);
            
            return new FracAtom(cmd, numerator, denominator);
        } finally {
            recursionDepth--;
        }
    }
    
    /**
     * <sqrt> ::= "\sqrt" [ "[" <math_list> "]" ] "{" <math_list> "}"
     */
    private SqrtAtom parseSqrt() throws ParseException {
        expect(Token.Type.COMMAND);  // \sqrt
        
        MathList root = null;
        
        // 可选的根次数 [n]
        if (check(Token.Type.LBRACKET)) {
            advance();
            recursionDepth++;
            try {
                root = parseMathList();
                expect(Token.Type.RBRACKET);
            } finally {
                recursionDepth--;
            }
        }
        
        // 被开方数 {x}
        expect(Token.Type.LBRACE);
        recursionDepth++;
        try {
            MathList content = parseMathList();
            expect(Token.Type.RBRACE);
            return new SqrtAtom(content, root);
        } finally {
            recursionDepth--;
        }
    }
    
    /**
     * <function_call> ::= "\" <function_name> [ "_" <script_arg> ] [ "^" <script_arg> ] [ <function_arg> ]
     */
    private FunctionCallAtom parseFunctionCall() throws ParseException {
        Token token = expect(Token.Type.COMMAND);
        String functionName = token.value;
        
        ScriptArg subscript = null;
        ScriptArg superscript = null;
        
        // 下标（如 \log_2）
        if (check(Token.Type.UNDERSCORE)) {
            advance();
            subscript = parseScriptArg();
        }
        
        // 上标
        if (check(Token.Type.CARET)) {
            advance();
            superscript = parseScriptArg();
        }
        
        // 函数参数（可选，只吃一个token或group）
        MathNode argument = null;
        if (check(Token.Type.LBRACE)) {
            argument = parseGroup();
        } else if (isSingleToken()) {
            Token argToken = advance();
            argument = new SingleTokenScriptArg(argToken.value);
        }
        
        return new FunctionCallAtom(functionName, subscript, superscript, argument);
    }
    
    /**
     * <large_operator> ::= "\" <large_op_name> [ "_" <script_arg> ] [ "^" <script_arg> ]
     */
    private LargeOperatorAtom parseLargeOperator() throws ParseException {
        Token token = expect(Token.Type.COMMAND);
        String operatorName = token.value;
        
        ScriptArg subscript = null;
        ScriptArg superscript = null;
        
        // 可以是 _{}^{} 或 ^{}_{}
        if (check(Token.Type.UNDERSCORE)) {
            advance();
            subscript = parseScriptArg();
            if (check(Token.Type.CARET)) {
                advance();
                superscript = parseScriptArg();
            }
        } else if (check(Token.Type.CARET)) {
            advance();
            superscript = parseScriptArg();
            if (check(Token.Type.UNDERSCORE)) {
                advance();
                subscript = parseScriptArg();
            }
        }
        
        return new LargeOperatorAtom(operatorName, subscript, superscript);
    }
    
    /**
     * <sup_sub_suffix> ::= "^" <script_arg> | "_" <script_arg> 
     *                    | "^" <script_arg> "_" <script_arg>
     *                    | "_" <script_arg> "^" <script_arg>
     */
    private SupSubSuffix tryParseSupSubSuffix() throws ParseException {
        ScriptArg superscript = null;
        ScriptArg subscript = null;
        
        if (check(Token.Type.CARET)) {
            advance();
            superscript = parseScriptArg();
            
            if (check(Token.Type.UNDERSCORE)) {
                advance();
                subscript = parseScriptArg();
            }
        } else if (check(Token.Type.UNDERSCORE)) {
            advance();
            subscript = parseScriptArg();
            
            if (check(Token.Type.CARET)) {
                advance();
                superscript = parseScriptArg();
            }
        } else {
            return null;  // 没有上下标
        }
        
        return new SupSubSuffix(superscript, subscript);
    }
    
    /**
     * <script_arg> ::= <single_token> | <group>
     */
    private ScriptArg parseScriptArg() throws ParseException {
        if (check(Token.Type.LBRACE)) {
            GroupAtom group = parseGroup();
            return new GroupScriptArg(group.content);
        } else if (isSingleToken()) {
            Token token = advance();
            return new SingleTokenScriptArg(token.value);
        } else {
            throw new ParseException("Expected script argument", currentToken().position);
        }
    }
    
    // ========== 辅助方法 ==========
    
    private void checkRecursionDepth() throws ParseException {
        if (recursionDepth > MAX_RECURSION_DEPTH) {
            throw new ParseException("Maximum recursion depth exceeded", currentToken().position);
        }
    }
    
    private boolean isBinaryOperator() {
        Token token = currentToken();
        if (token.type == Token.Type.SYMBOL) {
            return BINARY_OPERATORS.contains(token.value);
        } else if (token.type == Token.Type.COMMAND) {
            return BINARY_OPERATORS.contains(token.value);
        }
        return false;
    }
    
    private String consumeBinaryOperator() throws ParseException {
        Token token = advance();
        if (token.type == Token.Type.COMMAND) {
            return "\\" + token.value;
        }
        return token.value;
    }
    
    private boolean isSingleToken() {
        Token token = currentToken();
        return token.type == Token.Type.NUMBER 
            || token.type == Token.Type.LETTER
            || (token.type == Token.Type.COMMAND && GREEK_LETTERS.contains(token.value));
    }
    
    private Token currentToken() {
        return tokens.get(pos);
    }
    
    private Token advance() {
        return tokens.get(pos++);
    }
    
    private boolean check(Token.Type type) {
        return currentToken().type == type;
    }
    
    private Token expect(Token.Type type) throws ParseException {
        Token token = currentToken();
        if (token.type != type) {
            throw new ParseException("Expected " + type + ", got " + token.type, token.position);
        }
        return advance();
    }
}

// ==================== 异常类 ====================

class ParseException extends Exception {
    int position;
    
    public ParseException(String message, int position) {
        super(message + " at position " + position);
        this.position = position;
    }
}

// ==================== 测试示例 ====================

class MathParserExample {
    public static void main(String[] args) {
        String[] testCases = {
            "x^2",
            "x^{n+1}",
            "x^a+b",
            "\\frac{1}{2}",
            "\\sqrt{x+1}",
            "\\sum_{i=1}^{n} i^2",
            "\\sin x + y",
            "\\alpha + \\beta",
            "a+b*c"
        };
        
        for (String testCase : testCases) {
            System.out.println("\n输入: " + testCase);
            try {
                Lexer lexer = new Lexer(testCase);
                List<Token> tokens = lexer.tokenize();
                System.out.println("Tokens: " + tokens);
                
                MathParser parser = new MathParser(tokens);
                MathList ast = parser.parse();
                System.out.println("解析成功!");
                System.out.println("输出: " + ast.toLatex());
                
            } catch (ParseException e) {
                System.out.println("解析错误: " + e.getMessage());
            }
        }
    }
}

