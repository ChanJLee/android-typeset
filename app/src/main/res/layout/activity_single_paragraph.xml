<?xml version="1.0" encoding="utf-8"?>
<me.chan.androidtex.MyLinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".SingleParagraphActivity">

    <me.chan.androidtex.MyButton
        android:id="@+id/increase_padding"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Increase padding" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Chronometer
                android:id="@+id/clock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#009688"
                android:textSize="20dp"
                tools:text="from《3 rules to Help you build a successful business 》" />

            <me.chan.texas.renderer.ui.text.ParagraphView
                android:id="@+id/paragraph"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#4CAF50"
                app:me_chan_texas_ParagraphView_textSize="20dp" />

            <me.chan.texas.renderer.ui.text.ParagraphView
                android:id="@+id/paragraph2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#4CAF50"
                app:me_chan_texas_ParagraphView_textSize="20dp"
                tools:me_chan_texas_ParagraphView_text="hello" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#8BC34A"
                android:text="hello"
                android:textSize="20dp" />

            <me.chan.androidtex.TestView
                android:id="@+id/test_view"
                android:layout_width="match_parent"
                android:layout_height="100dp" />
        </LinearLayout>
    </ScrollView>
</me.chan.androidtex.MyLinearLayout>