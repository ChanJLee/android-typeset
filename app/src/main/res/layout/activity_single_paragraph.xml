<?xml version="1.0" encoding="utf-8"?>
<me.chan.androidtex.MyLinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".SingleParagraphActivity">

    <me.chan.androidtex.MyButton
        android:id="@+id/increase_padding"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Increase padding" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#009688"
                android:textSize="20dp"
                tools:text="from《3 rules to Help you build a successful business 》" />

            <com.shanbay.lib.texas.renderer.ui.text.ParagraphView
                android:id="@+id/paragraph"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#4CAF50"
                app:com_shanbay_lib_texas_paragraph_textSize="20dp" />
        </LinearLayout>
    </ScrollView>
</me.chan.androidtex.MyLinearLayout>