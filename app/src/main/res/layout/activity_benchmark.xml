<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="me.chan.texas.BenchmarkActivity">


    <TextView
        android:id="@+id/raw"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F0ACA6"
        android:includeFontPadding="false"
        android:text="AVAVWAWA asdasdasd (תפוח) 123"
        android:textSize="70sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:me_chan_texas_ParagraphView_textColor="#FF5722" />

    <me.chan.texas.renderer.ui.text.ParagraphView
        android:id="@+id/paragraph"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#112196F3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:me_chan_texas_ParagraphView_bidiEnable="true"
        app:me_chan_texas_ParagraphView_breakStrategy="simple"
        app:me_chan_texas_ParagraphView_debugEnable="true"
        app:me_chan_texas_ParagraphView_text="AVAVWAWA asdasdasd (תפוח) 123"
        app:me_chan_texas_ParagraphView_textColor="#FF5722"
        app:me_chan_texas_ParagraphView_textSize="70sp"
        app:me_chan_texas_ParagraphView_typefaceAssets="opposans_r.ttf" />

    <me.chan.texas.BenchmarkView
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="#FF9800"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/raw" />
</androidx.constraintlayout.widget.ConstraintLayout>