<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="me.chan.texas.MathSymbolBenchmarkActivity">

    <me.chan.texas.MathView
        android:id="@+id/math_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="bottom|center_horizontal"
        android:orientation="vertical">

        <RadioGroup
            android:id="@+id/height"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/large"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="使用常量高度Large" />

            <RadioButton
                android:id="@+id/small"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="使用常量高度Small" />
        </RadioGroup>

        <CheckBox
            android:id="@+id/include_top_padding"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="包含top padding" />

        <CheckBox
            android:id="@+id/include_bottom_padding"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="包含bottom padding" />

        <TextView
            android:id="@+id/indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="16dp"
            android:text="点我开始"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/save"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="50dp"
            android:text="保存"
            android:textSize="24sp" />>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>