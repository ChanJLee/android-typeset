<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="TexasView">
        <attr name="android:padding" />
        <attr name="android:paddingLeft" />
        <attr name="android:paddingRight" />
        <attr name="android:paddingTop" />
        <attr name="android:paddingBottom" />
        <attr name="textColor" />
        <attr name="textSize" />
        <attr name="lineSpacingExtra" />
        <attr name="gravity" />
        <attr name="typefaceAssets" format="string" />
        <attr name="selectedBackgroundColor" format="color" />
        <attr name="selectedTextColor" format="color" />
        <attr name="spanSelectedBackgroundColor" format="color" />
        <attr name="spanSelectedTextColor" format="color" />
        <attr name="breakStrategy" format="enum">
            <enum name="simple" value="1" />
            <enum name="balance" value="2" />
        </attr>
        <attr name="wordSelectable" format="boolean" />
        <attr name="hyphenStrategy" format="enum">
            <enum name="us" value="1" />
            <enum name="uk" value="2" />
        </attr>
        <attr name="lazyRender" format="boolean" />
        <attr name="spanHighlightTextColor" format="color" />
        <attr name="loadingBackgroundColor" format="color" />
        <attr name="dragViewColor" format="color" />
        <attr name="selectedBackgroundRoundRadius" format="dimension" />
        <attr name="compatMode" format="boolean" />
        <attr name="dragToSelectionEnable" format="boolean" />
        <attr name="bidiEnable" format="boolean" />
    </declare-styleable>

    <style name="TexasRecyclerView" parent="android:Widget">
        <item name="android:scrollbars">vertical</item>
        <item name="android:scrollbarStyle">outsideOverlay</item>
        <item name="android:scrollbarThumbVertical">
            @drawable/me_chan_texas_scrollbar_thumb
        </item>
        <item name="android:scrollbarTrackVertical">@null</item>
    </style>

    <declare-styleable name="ParagraphView">
        <attr name="textColor" />
        <attr name="textSize" />
        <attr name="lineSpacingExtra" />
        <attr name="text" />
        <attr name="minLines" />
        <attr name="maxLines" />
        <attr name="gravity" />
        <attr name="typefaceAssets" />
        <attr name="debugEnable" format="boolean" />
        <attr name="selectedBackgroundColor" />
        <attr name="selectedTextColor" />
        <attr name="spanSelectedBackgroundColor" />
        <attr name="spanSelectedTextColor" />
        <attr name="breakStrategy" />
        <attr name="wordSelectable" />
        <attr name="hyphenStrategy" />
        <attr name="selectedBackgroundRoundRadius" />
        <attr name="compatMode" />
        <attr name="dragToSelectionEnable" />
        <attr name="bidiEnable" />
        <attr name="lines" format="integer" />
    </declare-styleable>
</resources>