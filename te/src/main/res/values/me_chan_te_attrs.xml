<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <declare-styleable name="me_chan_te_TeView">
        <attr name="textSize" format="dimension" tools:ignore="ResourceName" />
        <attr name="breakStrategy" format="enum" tools:ignore="ResourceName">
            <enum name="simple" value="1" />
            <enum name="balance" value="2" />
        </attr>
        <attr name="wordSelectable" format="boolean" tools:ignore="ResourceName" />
        <attr name="lineSpace" format="dimension" tools:ignore="ResourceName" />
        <attr name="textColor" format="color" tools:ignore="ResourceName" />
        <attr name="segmentSpace" format="dimension" tools:ignore="ResourceName" />
        <attr name="parser" format="string" tools:ignore="ResourceName" />
        <attr name="mode" format="enum" tools:ignore="ResourceName">
            <enum name="paging" value="1" />
            <enum name="sliding" value="2" />
        </attr>
    </declare-styleable>
</resources>