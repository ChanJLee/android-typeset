<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="me_chan_te_TeView">
        <attr name="me_chan_te_textColor" format="color" />
        <attr name="me_chan_te_typefaceAssets" format="string" />
        <attr name="me_chan_te_textSize" format="dimension" />
        <attr name="me_chan_te_lineSpace" format="dimension" />
        <attr name="me_chan_te_indent" format="boolean" />
        <attr name="me_chan_te_selectedBackgroundColor" format="color" />
        <attr name="me_chan_te_selectedTextColor" format="color" />
        <attr name="me_chan_te_spanSelectedBackgroundColor" format="color" />
        <attr name="me_chan_te_spanSelectedTextColor" format="color" />
        <attr name="me_chan_te_segmentSpace" format="dimension" />
        <attr name="me_chan_te_breakStrategy" format="enum">
            <enum name="simple" value="1" />
            <enum name="balance" value="2" />
        </attr>
        <attr name="me_chan_te_render_mode" format="enum">
            <enum name="paging" value="1" />
            <enum name="sliding" value="2" />
        </attr>
        <attr name="me_chan_te_wordSelectable" format="boolean" />
        <attr name="me_chan_te_underlineColor" format="color" />
        <!-- TODO       <attr name="me_chan_te_includePadding" format="boolean" />-->
    </declare-styleable>
</resources>